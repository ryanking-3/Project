<%- include("partials/header") %>

<h1 class="mb-4">Dashboard</h1>

<div class="card p-3 mb-4">
  <form action="/topics/create" method="POST" class="d-flex gap-2">
    <input class="form-control" name="name" placeholder="New topic" required>
    <button class="btn btn-primary">Create</button>
  </form>
</div>

<% data.forEach(topic => { %>

  <div class="card p-3 mb-3">

    <h5><%= topic.topicName %></h5>

    <form action="/topics/message" method="POST" class="d-flex gap-2 mb-3">
      <input class="form-control" name="content" placeholder="Message..." required>
      <button class="btn btn-success">Post</button>
    </form>

    <% topic.messages.forEach(msg => { %>
      <div class="message-box">
        <%= msg.content %>
      </div>
    <% }) %>

  </div>

<% }) %>

<%- include("partials/footer") %>
