<%- include('partials/header') %>

<h2 class="mb-3">Dashboard</h2>

<div class="mb-3">
  <a href="/topics/new" class="btn btn-primary">+ New Topic</a>
  <a href="/topics" class="btn btn-info">Browse Topics</a>
  <a href="/topics/stats" class="btn btn-secondary">Stats</a>
</div>

<% if (data.length === 0) { %>
  <p>You are not subscribed to any topics yet.</p>
<% } %>

<% data.forEach(d => { %>
  <div class="card mt-3 p-3">

    <div class="d-flex justify-content-between align-items-center">
      <h4>
        <a href="/topics/<%= d.topic._id %>"><%= d.topic.title %></a>
      </h4>

      <form method="POST" action="/topics/<%= d.topic._id %>/unsubscribe">
        <button class="btn btn-outline-danger btn-sm">Unsubscribe</button>
      </form>
    </div>

    <hr>

    <% if (d.messages.length === 0) { %>
      <p>No messages yet.</p>
    <% } %>

    <% d.messages.forEach(m => { %>
      <p>
        <strong><%= m.author.username %>:</strong>
        <%= m.content %>
      </p>
    <% }) %>

  </div>
<% }) %>

<%- include('partials/footer') %>