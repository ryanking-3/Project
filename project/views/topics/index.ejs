<%- include('../partials/header') %>

<h2>Browse Topics</h2>

<a href="/topics/dashboard" class="btn btn-secondary mb-3">Back</a>

<% topics.forEach(t => { %>
  <div class="card p-3 mt-2">
    <h4><%= t.title %></h4>

    <% if (subscriptions.includes(t._id.toString())) { %>
      <span class="badge bg-success">Subscribed</span>
    <% } else { %>
      <form method="POST" action="/topics/<%= t._id %>/subscribe">
        <button class="btn btn-primary btn-sm">Subscribe</button>
      </form>
    <% } %>
  </div>
<% }) %>

<%- include('../partials/footer') %>
