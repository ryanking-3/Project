<%- include('../partials/header', { title: 'Topics' }) %>
<div class="max-w-5xl mx-auto px-6 py-12">
  <div class="flex justify-between items-end mb-12">
    <h1 class="font-serif text-5xl italic">All Posts</h1>
    <a href="/topics/new" class="bg-brandAccent text-black px-6 py-2 rounded-full font-bold hover:scale-105 transition">+ New Topic</a>
  </div>
  <div class="divide-y divide-brandBorder">
    <% topics.forEach(topic => { %>
      <% const isSubscribed = subscribedIds.includes(topic._id.toString()); %>
      <div class="py-8 flex justify-between items-center group">
        <div>
          <a href="/topics/<%= topic._id %>" class="font-serif text-2xl group-hover:text-brandAccent transition"><%= topic.title %></a>
          <div class="text-[11px] font-mono uppercase text-gray-500 mt-1">Started by @<%= topic.createdBy.username %></div>
        </div>
        <div class="flex items-center gap-4">
          <% if (isSubscribed) { %>
            <form action="/topics/<%= topic._id %>/unsubscribe" method="POST">
              <button class="text-xs text-red-400 font-bold underline transition">Unsubscribe</button>
            </form>
          <% } else { %>
            <form action="/topics/<%= topic._id %>/subscribe" method="POST">
              <button class="bg-brandAccent text-black px-6 py-2 rounded-full text-sm font-bold hover:opacity-80 transition">Subscribe</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include('../partials/footer') %>