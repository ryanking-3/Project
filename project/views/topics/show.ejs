<%- include('../partials/header', { title: topic.title }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12 border-b border-brandBorder pb-8">
        <h1 class="font-serif text-5xl mb-4 italic text-brandAccent"><%= topic.title %>/</h1>
        <p class="text-gray-500 font-mono text-[10px] uppercase tracking-widest">Views: <%= topic.accessCount %></p>
    </div>

    <div class="space-y-6 mb-16">
        <h2 class="font-mono text-[10px] text-gray-500 uppercase tracking-[0.3em] mb-4">Message Log/</h2>
        <% if (messages && messages.length > 0) { %>
            <% // Controller already sorts by createdAt: -1, we just limit to 2 for T2.1 %>
            <% messages.slice(0, 2).forEach(msg => { %>
                <div class="bg-brandSurface p-6 rounded-xl border border-brandBorder">
                    <p class="text-gray-300 font-mono text-sm mb-2"><%= msg.content %></p>
                    <span class="text-[10px] text-brandAccent uppercase">Sent by: <%= msg.author ? msg.author.username : 'Anonymous' %></span>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-gray-600 italic font-mono text-sm">No messages yet.</p>
        <% } %>
    </div>

    <% if (isSubscribed) { %>
    <div class="bg-brandSurface p-8 rounded-2xl border border-brandAccent/20">
        <h3 class="font-serif text-2xl mb-6 italic">Post Transmission/</h3>
        <form action="/topics/<%= topic._id %>/messages" method="POST" class="space-y-4">
            <textarea 
                name="content" 
                rows="4" 
                required 
                placeholder="Type your message..." 
                class="w-full bg-[#0d0d0d] border border-brandBorder rounded-lg p-4 font-mono text-sm text-white placeholder-gray-700 focus:border-brandAccent outline-none transition"
            ></textarea>
            <button type="submit" class="bg-brandAccent text-black font-mono text-[10px] px-8 py-3 rounded-full uppercase font-bold tracking-widest hover:bg-white transition">
                Send Message
            </button>
        </form>
    </div>
    <% } else { %>
        <p class="text-gray-500 font-mono text-xs italic text-center border border-dashed border-brandBorder py-8 rounded-xl">
            Subscribe to this topic to join the conversation.
        </p>
    <% } %>
</div>

<%- include('../partials/footer') %>