<%- include('../partials/header', { title: topic.title }) %>
<main class="max-w-4xl mx-auto px-6 py-12">
  <header class="mb-12 border-b border-brandBorder pb-8">
    <h1 class="font-serif text-5xl italic mb-4"><%= topic.title %></h1>
    <p class="text-gray-400 mb-6"><%= topic.description %></p>
    <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">
      Views: <%= topic.accessCount %> | Author: @<%= topic.createdBy.username %>
    </div>
  </header>

  <div class="space-y-6 mb-12">
    <% topic.messages.forEach(msg => { %>
      <div class="bg-brandSurface border border-brandBorder p-5 rounded-2xl">
        <div class="text-xs font-mono text-brandAccent mb-2">@<%= msg.author.username %></div>
        <p class="text-gray-300"><%= msg.content %></p>
      </div>
    <% }) %>
  </div>

  <% if (isSubscribed) { %>
    <form action="/topics/<%= topic._id %>/messages" method="POST" class="bg-brandSurface p-6 rounded-2xl border border-brandAccent/20">
      <textarea name="content" required placeholder="Write a message..." class="w-full bg-brandBg border border-brandBorder rounded-xl p-4 focus:outline-none focus:border-brandAccent transition mb-4"></textarea>
      <button class="bg-brandAccent text-black font-bold px-8 py-2 rounded-full">Post Message</button>
    </form>
  <% } %>
</main>
<%- include('../partials/footer') %>