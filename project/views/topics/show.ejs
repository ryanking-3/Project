<%- include('../partials/header', { title: topic.title }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12 border-b border-brandBorder pb-8">
        <h1 class="font-serif text-5xl mb-4 italic text-brandAccent"><%= topic.title %>/</h1>
        <p class="text-gray-500 font-mono text-[10px] uppercase tracking-widest">Live Stats: <%= topic.accessCount %> Access Events</p>
    </div>

    <div class="space-y-6 mb-16">
        <h2 class="font-mono text-[10px] text-gray-500 uppercase tracking-[0.3em] mb-4">T2.1: Recent Correspondence/</h2>
        <% if (topic.messages && topic.messages.length > 0) { %>
            <% // Slice -2 gets the last two messages added to the array %>
            <% topic.messages.slice(-2).reverse().forEach(msg => { %>
                <div class="bg-brandSurface p-6 rounded-xl border border-brandBorder">
                    <p class="text-gray-300 font-mono text-sm mb-2"><%= msg.content %></p>
                    <span class="text-[10px] text-brandAccent uppercase">Origin: <%= msg.author.username || 'Anonymous' %></span>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-gray-600 italic font-mono text-sm">No transmissions recorded in this thread.</p>
        <% } %>
    </div>

    <div class="bg-brandSurface p-8 rounded-2xl border border-brandAccent/20">
        <h3 class="font-serif text-2xl mb-6 italic">T4: Broadcast Transmission/</h3>
        
        <form action="/topics/<%= topic._id %>/messages" method="POST" class="space-y-4">
            <textarea 
                name="content" 
                rows="3" 
                required 
                placeholder="Enter encrypted message..." 
                class="w-full bg-brandBg border border-brandBorder rounded-lg p-4 font-mono text-sm text-white focus:border-brandAccent outline-none transition"
            ></textarea>
            
            <button type="submit" class="bg-brandAccent text-black font-mono text-[10px] px-8 py-3 rounded-full uppercase font-bold tracking-widest hover:bg-white transition">
                Post Message
            </button>
        </form>
    </div>

    <div class="mt-12">
        <a href="/topics" class="text-[10px] font-mono text-gray-500 hover:text-brandAccent transition uppercase tracking-widest">← Back to Index</a>
    </div>
</div>

<%- include('../partials/footer') %>