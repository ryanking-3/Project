<%- include('../partials/header', { title: topic.title }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12 border-b border-brandBorder pb-8">
        <h1 class="font-serif text-5xl mb-4 italic text-[#E8FF4D]"><%= topic.title %>/</h1>
        <p class="text-gray-500 font-mono text-[10px] uppercase tracking-widest">Analytics: <%= topic.accessCount %> Accesses</p>
    </div>

    <div class="space-y-6 mb-16">
        <% if (messages && messages.length > 0) { %>
            <% messages.forEach(msg => { %>
                <div class="bg-brandSurface p-6 rounded-xl border border-brandBorder">
                    <p class="text-gray-200 font-mono text-sm mb-3"><%= msg.content %></p>
                    <div class="flex gap-4 text-[10px] font-mono uppercase text-gray-500">
                        <span class="text-[#E8FF4D]">Author: @<%= msg.author ? msg.author.username : 'Unknown' %></span>
                        <span>Sent: <%= msg.createdAt.toLocaleString() %></span>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-gray-600 italic font-mono text-sm text-center py-10">Thread is currently empty.</p>
        <% } %>
    </div>

    <% if (isSubscribed) { %>
        <div class="bg-[#0f0f0f] p-8 rounded-3xl border border-[#E8FF4D]/10 shadow-2xl">
            <h3 class="font-serif text-2xl mb-6 italic text-white">Broadcast/</h3>
            <form action="/topics/<%= topic._id %>/messages" method="POST" class="flex flex-col gap-4">
                <textarea 
                    name="content" 
                    rows="4" 
                    required 
                    placeholder="Type your transmission..." 
                    class="w-full bg-[#050505] border border-brandBorder rounded-xl p-4 font-mono text-sm text-white focus:border-[#E8FF4D] outline-none transition-all"
                ></textarea>
                <button type="submit" class="bg-[#E8FF4D] text-black font-mono text-xs px-10 py-4 rounded-full uppercase font-black hover:bg-white transition-all self-start">
                    Submit Message
                </button>
            </form>
        </div>
    <% } else { %>
        <div class="bg-[#0f0f0f] p-10 rounded-3xl border border-dashed border-brandBorder text-center">
            <p class="text-gray-500 font-mono text-xs uppercase tracking-widest mb-6">Subscription required to post to this thread.</p>
            <form action="/topics/<%= topic._id %>/subscribe" method="POST">
                <button type="submit" class="bg-white text-black font-mono text-[10px] px-8 py-3 rounded-full uppercase font-bold hover:bg-[#E8FF4D] transition-all">
                    Join Conversation
                </button>
            </form>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>