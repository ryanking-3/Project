<%- include('../partials/header', { title: topic.title }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12 border-b border-brandBorder pb-8">
        <h1 class="font-serif text-5xl mb-4 italic text-[#E8FF4D]"><%= topic.title %>/</h1>
        <div class="flex justify-between items-center">
            <p class="text-gray-500 font-mono text-[10px] uppercase tracking-widest">
                Analytics: <%= topic.accessCount %> Accesses
            </p>
            <a href="/dashboard" class="text-[10px] font-mono text-gray-500 hover:text-white uppercase">← Dashboard</a>
        </div>
    </div>

    <div class="space-y-6 mb-16">
        <% if (messages && messages.length > 0) { %>
            <% messages.forEach(msg => { %>
                <div class="bg-brandSurface p-6 rounded-xl border border-brandBorder">
                    <p class="text-gray-200 font-mono text-sm mb-4">"<%= msg.content %>"</p>
                    
                    <div class="flex gap-4 text-[9px] font-mono uppercase">
                        <span class="text-[#E8FF4D]">@<%= msg.author ? msg.author.username : 'Unknown' %></span>
                        <span class="text-gray-600">Timestamp: <%= msg.createdAt.toLocaleString('en-GB', { dateStyle: 'short', timeStyle: 'short' }) %></span>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-gray-600 italic font-mono text-sm text-center py-10 border border-dashed border-brandBorder rounded-xl">Thread is currently silent.</p>
        <% } %>
    </div>

    <% if (isSubscribed) { %>
        <div class="bg-[#111111] p-8 rounded-3xl border border-[#E8FF4D]/20">
            <h3 class="font-serif text-2xl mb-6 italic text-white">New Transmission/</h3>
            <form action="/topics/<%= topic._id %>/messages" method="POST" class="flex flex-col gap-4">
                <textarea 
                    name="content" 
                    rows="4" 
                    required 
                    placeholder="Enter message..." 
                    class="w-full bg-[#050505] border border-brandBorder rounded-xl p-4 font-mono text-sm text-white focus:border-[#E8FF4D] outline-none transition-all"
                ></textarea>
                <button type="submit" class="bg-[#E8FF4D] text-black font-mono text-[10px] px-10 py-4 rounded-full uppercase font-black hover:bg-white transition-all self-start">
                    Post Message
                </button>
            </form>
        </div>
    <% } else { %>
        <div class="bg-[#111111] p-10 rounded-3xl border border-dashed border-brandBorder text-center">
            <p class="text-gray-500 font-mono text-[10px] uppercase tracking-widest mb-6">Join the thread to participate</p>
            <form action="/topics/<%= topic._id %>/subscribe" method="POST">
                <button type="submit" class="bg-white text-black font-mono text-[10px] px-8 py-3 rounded-full uppercase font-bold hover:bg-[#E8FF4D] transition-all">
                    Subscribe to Topic
                </button>
            </form>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>