<%- include('../partials/header', { title: 'New Topic' }) %>

<form action="/topics/new" method="POST" class="space-y-6">
    <input type="text" name="title" required placeholder="Topic Title" 
           class="w-full bg-[#0a0a0a] border border-brandBorder p-4 rounded-xl text-white">
    
    <textarea name="description" placeholder="Description" 
              class="w-full bg-[#0a0a0a] border border-brandBorder p-4 rounded-xl text-white"></textarea>
    
    <button type="submit" class="w-full bg-[#E8FF4D] text-black font-bold py-4 rounded-xl">
        Create Topic
    </button>
</form>

<%- include('../partials/footer') %>