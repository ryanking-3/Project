<%- include('../partials/header', { title: 'New Topic' }) %>

<div class="container" style="max-width: 600px;">
  <div class="page-header">
    <h1>Start a New Topic</h1>
    <p class="subtitle">You'll be automatically subscribed when you create it</p>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="card">
    <div>
      <div class="form-group">
        <label for="title">Topic Title</label>
        <input type="text" id="title" name="title" form="new-topic-form" required placeholder="What's this topic about?">
      </div>
      <div class="form-group">
        <label for="description">Description <span class="card-meta">(optional)</span></label>
        <textarea id="description" name="description" form="new-topic-form" placeholder="Add context for this topic..."></textarea>
      </div>
      <div class="flex gap-1 items-center" style="gap: 0.6rem;">
        <button type="submit" form="new-topic-form" class="btn btn-primary">Create Topic</button>
        <a href="/topics" class="btn btn-outline">Cancel</a>
      </div>
    </div>
    <form id="new-topic-form" action="/topics" method="POST" style="display:none"></form>
  </div>
</div>

<%- include('../partials/footer') %>