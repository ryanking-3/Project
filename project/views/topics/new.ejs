<%- include('../partials/header', { title: 'New Topic' }) %>

<div class="max-w-2xl mx-auto px-6 py-20">
  <div class="mb-10 text-center">
    <h1 class="font-serif text-5xl mb-2 italic">Start a Thread</h1>
    <p class="text-gray-500 font-mono text-xs uppercase tracking-widest">Create a space for conversation</p>
  </div>

  <div class="bg-brandSurface border border-brandBorder p-8 rounded-3xl shadow-2xl">
    <form action="/topics" method="POST" class="space-y-6">
      <div>
        <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-[0.2em]">Topic Title</label>
        <input type="text" name="title" required placeholder="What are we talking about?"
               class="w-full bg-brandBg border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-brandAccent transition text-white">
      </div>

      <div>
        <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-[0.2em]">Description (Optional)</label>
        <textarea name="description" rows="4" placeholder="Add some context..."
                  class="w-full bg-brandBg border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-brandAccent transition text-white"></textarea>
      </div>

      <div class="flex gap-4 pt-4">
        <button type="submit" class="flex-1 bg-brandAccent text-black font-bold py-4 rounded-xl hover:opacity-90 transition shadow-lg shadow-brandAccent/10">
          Create Topic
        </button>
        <a href="/topics" class="flex-1 border border-brandBorder text-gray-400 font-bold py-4 rounded-xl text-center hover:bg-white hover:text-black transition">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>