<%- include('../partials/header', { title: 'Register' }) %>

<div class="auth-box">
  <h1>Create account</h1>
  <p class="auth-sub">Join Thread/ today</p>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div>
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" form="reg-form" required placeholder="choose_a_username">
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" form="reg-form" required placeholder="you@example.com">
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" form="reg-form" required placeholder="••••••••">
    </div>
    <div class="form-group">
      <label for="confirmPassword">Confirm Password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" form="reg-form" required placeholder="••••••••">
    </div>
    <button type="submit" form="reg-form" class="btn btn-primary" style="width:100%">Create Account</button>
  </div>
  <form id="reg-form" action="/register" method="POST" style="display:none"></form>

  <p class="auth-switch">Already have an account? <a href="/login">Login</a></p>
</div>

<%- include('../partials/footer') %>