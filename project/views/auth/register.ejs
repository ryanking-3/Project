<%- include('../partials/header', { title: 'Register' }) %>

<div class="max-w-md mx-auto py-20 px-6">
    <div class="text-center mb-10">
        <h1 class="font-serif text-5xl mb-2 italic text-white">Join Thread/</h1>
        <p class="text-gray-500 font-mono text-xs uppercase tracking-widest">Establish your credentials</p>
    </div>

    <div class="bg-brandSurface border border-brandBorder p-8 rounded-3xl shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-[#E8FF4D]"></div>

        <form action="/register" method="POST" class="space-y-5">
            <div>
                <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-widest">Username</label>
                <input type="text" name="username" required placeholder="choose_handle"
                       class="w-full bg-[#0a0a0a] border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-[#E8FF4D] transition text-sm text-white">
            </div>

            <div>
                <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-widest">Email Address</label>
                <input type="email" name="email" required placeholder="name@domain.com"
                       class="w-full bg-[#0a0a0a] border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-[#E8FF4D] transition text-sm text-white">
            </div>

            <div>
                <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-widest">Password</label>
                <input type="password" name="password" required placeholder="••••••••"
                       class="w-full bg-[#0a0a0a] border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-[#E8FF4D] transition text-sm text-white">
            </div>

            <div>
                <label class="block text-[10px] font-mono text-gray-400 uppercase mb-2 tracking-widest">Confirm Password</label>
                <input type="password" name="confirmPassword" required placeholder="••••••••"
                       class="w-full bg-[#0a0a0a] border border-brandBorder rounded-xl px-4 py-3 focus:outline-none focus:border-[#E8FF4D] transition text-sm text-white">
            </div>

            <button type="submit" 
                    class="w-full bg-[#E8FF4D] text-black font-bold py-4 rounded-xl transition-all duration-300 hover:bg-white hover:shadow-[0_0_20px_rgba(232,255,77,0.4)] mt-4 active:scale-95 uppercase tracking-widest text-xs">
                Create Account
            </button>
        </form>
        
        <p class="mt-6 text-center text-[10px] font-mono text-gray-500 uppercase tracking-widest">
            Already registered? <a href="/login" class="text-[#E8FF4D] hover:underline">Sign In</a>
        </p>
    </div>
</div>

<%- include('../partials/footer') %>