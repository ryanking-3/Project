<%- include('partials/header', { title: 'Register' }) %>
<div class="max-w-md mx-auto py-20 px-6">
  <div class="text-center mb-10">
    <h1 class="font-serif text-5xl mb-2 italic">Join Thread/</h1>
    <p class="text-gray-500 font-mono text-xs uppercase tracking-widest">Create an account to start posting</p>
  </div>
  <div class="bg-brandSurface border border-brandBorder p-8 rounded-3xl shadow-2xl relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-brandAccent opacity-50"></div>
    <form action="/register" method="POST" class="space-y-5">
      <input type="text" name="username" required placeholder="Username" class="w-full bg-brandBg border border-brandBorder rounded-xl px-4 py-3 focus:border-brandAccent transition text-white">
      <input type="email" name="email" required placeholder="Email" class="w-full bg-brandBg border border-brandBorder rounded-xl px-4 py-3 focus:border-brandAccent transition text-white">
      <input type="password" name="password" required placeholder="Password" class="w-full bg-brandBg border border-brandBorder rounded-xl px-4 py-3 focus:border-brandAccent transition text-white">
      <button class="w-full bg-brandAccent text-black font-bold py-4 rounded-xl hover:opacity-90 transition shadow-lg">Create Account</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>