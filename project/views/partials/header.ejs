<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Posts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;700&display=swap');
        
        :root {
            --brand-bg: #0a0a0a;
            --brand-surface: #141414;
            --brand-border: #262626;
            --brand-accent: #e8ff4d;
        }

        body { 
            background-color: var(--brand-bg); 
            color: white;
            font-family: 'JetBrains Mono', monospace;
        }

        .font-serif { font-family: 'DM Serif Display', serif; }

        /* WORKAROUND CSS */
        .progress-fill {
            height: 100%;
            background-color: var(--brand-accent);
            box-shadow: 0 0 15px rgba(232, 255, 77, 0.5);
            transition: width 1s ease-out;
            /* This tells the bar to look for a custom variable named --pg-width */
            width: var(--pg-width, 0%); 
        }
    </style>
</head>
<body class="selection:bg-brandAccent selection:text-black">
    <nav class="border-b border-brandBorder py-6 px-8 flex justify-between items-center bg-brandBg/80 backdrop-blur-md sticky top-0 z-50">
        <a href="/" class="font-serif text-3xl italic tracking-tighter">Thread/</a>
        <div class="flex gap-8 text-[10px] uppercase tracking-[0.3em] font-bold">
            <a href="/topics" class="hover:text-brandAccent transition">Threads</a>
            <a href="/stats" class="hover:text-brandAccent transition text-brandAccent">Stats</a>
            <% if (locals.user) { %>
                <a href="/dashboard" class="hover:text-brandAccent transition">Dash</a>
                <a href="/logout" class="text-red-500 hover:text-red-400">Exit</a>
            <% } else { %>
                <a href="/login" class="hover:text-brandAccent transition">Login</a>
            <% } %>
        </div>
    </nav>