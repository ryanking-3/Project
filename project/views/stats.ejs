<%- include('../partials/header', { title: 'Statistics' }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
  <div class="text-center mb-16">
    <h1 class="font-serif text-6xl mb-4 italic text-brandAccent">Analytics/</h1>
    <p class="text-gray-500 font-mono text-xs uppercase tracking-[0.4em]">Tracking Thread Engagement</p>
  </div>

  <div class="space-y-6">
    <% topics.forEach((topic, i) => { %>
      <div class="bg-brandSurface p-8 rounded-2xl border border-brandBorder group hover:border-brandAccent/30 transition-all duration-500">
        <div class="flex justify-between items-end mb-4">
          <div class="flex items-center gap-4">
            <span class="font-mono text-gray-700 text-lg group-hover:text-brandAccent transition">0<%= i + 1 %></span>
            <a href="/topics/<%= topic._id %>" class="font-serif text-2xl hover:text-brandAccent transition"><%= topic.title %></a>
          </div>
          <span class="text-xs font-mono text-brandAccent font-bold"><%= topic.accessCount %> HITS</span>
        </div>
        
        <div class="h-1.5 bg-brandBg w-full rounded-full overflow-hidden border border-white/5">
          <div class="h-full bg-brandAccent shadow-[0_0_15px_rgba(232,255,77,0.5)] transition-all duration-1000 ease-out" 
               style="width: <%= (topic.accessCount / maxAccess * 100) %>%">
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>