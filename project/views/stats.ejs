<%- include('partials/header') %>

<h2 class="mb-4">Topic Statistics</h2>

<% if (topics.length === 0) { %>
  <p>No topics yet.</p>
<% } %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Topic</th>
      <th>Views</th>
    </tr>
  </thead>
  <tbody>
    <% topics.forEach(t => { %>
      <tr>
        <td><%= t.title %></td>
        <td><%= t.accessCount %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('partials/footer') %>