<%- include('partials/header', { title: 'Statistics' }) %>

<div class="max-w-4xl mx-auto px-6 py-20">
  <div class="text-center mb-16">
    <h1 class="font-serif text-6xl mb-4 italic text-brandAccent">Analytics/</h1>
    <p class="text-gray-500 font-mono text-[10px] uppercase tracking-[0.5em]">Engagement Metrics</p>
  </div>

  <div class="space-y-6">
    <% topics.forEach((topic, i) => { %>
      <div class="bg-brandSurface p-8 rounded-2xl border border-brandBorder group">
        <div class="flex justify-between items-end mb-6">
          <div class="flex items-center gap-4">
            <span class="font-mono text-gray-700 text-lg">0<%= i + 1 %></span>
            <span class="font-serif text-2xl italic"><%= topic.title %></span>
          </div>
          <span class="text-xs font-mono text-brandAccent font-bold"><%= topic.accessCount %> HITS</span>
        </div>
        
        <div class="h-1.5 bg-black/40 w-full rounded-full overflow-hidden border border-white/5">
          <% 
            let max = (locals.maxAccess && locals.maxAccess > 0) ? locals.maxAccess : 1;
            let percent = (topic.accessCount / max) * 100;
          %>
          <div class="progress-fill" style="--pg-width: <%= percent %>%;"></div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>