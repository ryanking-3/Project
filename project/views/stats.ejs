<%- include("partials/header") %>

<h1 class="mb-4">Topic Stats</h1>

<div class="row">

  <% topics.forEach(topic => { %>

    <div class="col-md-4 mb-3">
      <div class="card p-3 text-center shadow-sm">

        <h5><%= topic.name %></h5>
        <h2 class="text-primary"><%= topic.accessCount %></h2>

      </div>
    </div>

  <% }) %>

</div>

<%- include("partials/footer") %>